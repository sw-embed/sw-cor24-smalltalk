10 REM SMOKE: PEEK/POKE BELOW 1024 STORE FULL 24-BIT SIGNED WORDS
20 REM EXPECT: PRINTS 8388607, 1048576, 65536, 255, -1
30 POKE 100,8388607
40 PRINT "MAX ";PEEK(100)
50 POKE 101,1048576
60 PRINT "MID ";PEEK(101)
70 POKE 102,65536
80 PRINT "16K ";PEEK(102)
90 POKE 103,255
100 PRINT "BYT ";PEEK(103)
110 POKE 104,-1
120 PRINT "NEG ";PEEK(104)
130 END
RUN
BYE
