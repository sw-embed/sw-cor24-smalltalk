10 REM SMOKE: TAG-BIT EXTRACTION VIA V-(V/2)*2 WITHOUT MOD/AND
20 REM EXPECT: 0,1,0,1,0,1 FOR 0,1,2,3,4,5
30 FOR I=0 TO 5
40 LET T=I-(I/2)*2
50 PRINT I;"->";T
60 NEXT I
70 REM CHECK NEGATIVE: BASIC V1 INTEGER DIV TRUNCATES TOWARD ZERO
80 REM SO -3/2 = -1 AND -3-(-1)*2 = -1 (NOT 1!) WHICH IS A BUG WE
90 REM DOCUMENT: TAGGED REFS MUST BE NON-NEGATIVE FOR THIS TEST.
100 LET V=-3
110 LET T=V-(V/2)*2
120 PRINT "-3->";T
130 END
RUN
BYE
