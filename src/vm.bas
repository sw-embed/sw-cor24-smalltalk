9000 REM === COR24 SMALLTALK V0 VM CORE =================================
9001 REM HEAP / STACKS / DISPATCH / SEND / PRIMITIVES.
9002 REM ALL HELPERS ARE GOSUB-ONLY -- LINEAR FALL-THROUGH STOPS AT THE
9003 REM DRIVER'S "END" BEFORE LINE 9000.  ARGUMENT PASSING IS BY
9004 REM SHARED VARIABLE; SEE COMMENT AT EACH HELPER FOR INPUT/OUTPUT.
9005 REM
9006 REM DATA LAYOUT (DIM ARRAYS, ALL DIMMED IN INSTALL_SINGLETONS).
9007 REM SINGLE-LETTER NAMES; BASIC V1 SCALAR X AND ARRAY X() COEXIST,
9008 REM SO H/S/P/M/L/R/Y/C/G/A/B/K/O APPEAR AS BOTH SCALAR REGISTERS
9009 REM AND ARRAYS DEPENDING ON CONTEXT.
9010 REM   H(0..511)        HEAP ARENA, NIL/TRUE/FALSE AT 0/4/8.
9011 REM   S(0..127)        EVAL STACK.
9012 REM   P,M,L,R,Y(0..15) FRAME STACK PARALLEL ARRAYS:
9013 REM                    SAVED PC, METHOD ADDR, METHOD LEN,
9014 REM                    RECEIVER, AND CLEANUP_TARGET.
9015 REM   C,G,A,B(0..15)   METHOD-DICT PARALLEL ARRAYS:
9016 REM                    CLASS, SELECTOR, BCSTART (INDEX INTO O),
9017 REM                    BCLEN.
9018 REM   K(0..15)         CLASS_SUPER (K(0) = -1 TERMINATES).
9019 REM   O(0..127)        BYTECODE POOL.  SCALAR M IS METHOD'S
9020 REM                    BCSTART INDEX, P IS PC OFFSET, AND THE
9021 REM                    NEXT BYTECODE BYTE IS O(M+P).
9021 REM
9022 REM REGISTER USE: P=PC, M=METHOD ADDR, L=METHOD LEN, R=RECEIVER,
9023 REM C=CLASS, S=ESTACK PTR, F=FSTACK PTR, O=OPCODE, G=SELECTOR,
9024 REM N=ARGC, H=HEAP ALLOC, E=ERROR, A/B/D/Q/T/U/V/W=SCRATCH.
9025 REM I/J ARE LOOP-LOCAL IN HELPERS; THE DRIVER USES X/Y/Z.
9026 REM
9100 REM --- ISINT: IN V, OUT T (1 IF SMALLINT, 0 IF POINTER) -------------
9110 T=V MOD 2
9120 RETURN
9200 REM --- TOINT: IN V (TAGGED SMALLINT), OUT T = DECODED INT ------------
9210 T=V SHR 1
9220 RETURN
9300 REM --- MKINT: IN V (RAW INT), OUT T = TAGGED REF --------------------
9310 T=(V SHL 1) BOR 1
9320 RETURN
9400 REM --- PADDR: IN V (TAGGED HEAP REF), OUT T = HEAP INDEX ------------
9410 T=V SHR 1
9420 RETURN
9500 REM --- CLASSOF: IN V, OUT T = CLASS ID -----------------------------
9510 GOSUB 9100
9520 IF T=1 THEN T=2
9530 IF T=2 THEN RETURN
9540 GOSUB 9400
9550 T=H(T)
9560 RETURN
9700 REM --- ALLOC: IN C=CLASS, N=SIZE, OUT T = TAGGED REF ---------------
9710 IF H+3+N>512 THEN E=4
9720 IF E<>0 THEN RETURN
9730 LET H(H)=C
9740 LET H(H+1)=N
9750 LET H(H+2)=0
9760 T=H*2
9770 H=H+3+N
9780 RETURN
9900 REM --- EPUSH: IN V, EFFECT: STACK[S++] = V -------------------------
9910 IF S>=128 THEN E=4
9920 IF E<>0 THEN RETURN
9930 LET S(S)=V
9940 S=S+1
9950 RETURN
9960 REM --- EPOP: OUT T = STACK[--S] ------------------------------------
9970 IF S<=0 THEN E=4
9980 IF E<>0 THEN RETURN
9985 S=S-1
9990 T=S(S)
9995 RETURN
10100 REM --- INSTALL_SINGLETONS: REQUIRED ONCE AT BOOT -------------------
10110 REM ALLOCATES ALL VM ARRAYS, PLACES NIL (CLASS 5), TRUE (CLASS 3),
10120 REM FALSE (CLASS 4) AT HEAP INDICES 0, 4, 8.  H IS BUMPED TO 16.
10125 REM ALSO TERMINATES THE CLASS_SUPER CHAIN: K(0) = -1.
10126 DIM H(511), S(127), O(127)
10127 DIM P(15), M(15), L(15), R(15), Y(15)
10128 DIM C(15), G(15), A(15), B(15)
10129 DIM K(15)
10130 LET H(0)=5
10140 LET H(1)=0
10150 LET H(2)=0
10160 LET H(4)=3
10170 LET H(5)=0
10180 LET H(6)=0
10190 LET H(8)=4
10200 LET H(9)=0
10210 LET H(10)=0
10220 LET H(12)=6
10230 LET H(13)=0
10240 LET H(14)=0
10245 LET K(0)=-1
10250 H=16
10260 RETURN
10300 REM --- INSTALL_METHOD: IN C=CLASS, G=SEL, A=BCSTART, B=BCLEN -------
10310 REM WALK METHOD DICT (640..703, 16 ENTRIES * 4 WORDS) FOR FIRST
10320 REM EMPTY SLOT (CLASS = -1 OR 0) AND WRITE THE ENTRY.
10330 W=0
10340 IF W>=16 THEN E=4
10350 IF E<>0 THEN RETURN
10360 IF C(W)<=0 THEN GOTO 10380
10370 W=W+1
10375 GOTO 10340
10380 LET C(W)=C
10390 LET G(W)=G
10400 LET A(W)=A
10410 LET B(W)=B
10420 RETURN
10500 REM --- LOOKUP: IN C=CLASS, G=SEL, OUT Q=ENTRY INDEX OR -1 ----------
10501 REM ON A METHOD-DICTIONARY MISS, WALK K(C) (CLASS_SUPER) AND
10502 REM RETRY.  TERMINATES WHEN C GOES NEGATIVE (K(0) IS PRE-LOADED
10503 REM TO -1 BY INSTALL_SINGLETONS).
10505 IF C<0 THEN Q=-1
10506 IF C<0 THEN RETURN
10510 W=0
10520 IF W>=16 THEN GOTO 10590
10540 IF C(W)<>C THEN GOTO 10570
10550 IF G(W)<>G THEN GOTO 10570
10560 Q=W
10565 RETURN
10570 W=W+1
10580 GOTO 10520
10590 REM MISS IN CLASS C: WALK TO SUPERCLASS AND RETRY.
10595 C=K(C)
10596 GOTO 10505
10700 REM --- INIT_METHDICT: MARK ALL ENTRIES EMPTY (CLASS = -1) ---------
10710 W=0
10720 IF W>=16 THEN RETURN
10730 LET C(W)=-1
10740 W=W+1
10750 GOTO 10720
10800 REM --- READ_AND_INSTALL_METHODS: CONSUME A SELF-DESCRIBING DATA -
10801 REM STREAM AT THE CURRENT READ POINTER.  EACH METHOD RECORD IS
10802 REM   <CLASS> <SELECTOR> <BYTECOUNT> <BYTE0> <BYTE1> ... <BYTE_N-1>
10803 REM A SENTINEL RECORD <-1> 0 0 ENDS THE STREAM.  ALLOCATES
10804 REM CONSECUTIVE INDICES INTO O() STARTING AT 0.
10805 REM CALLER MUST RESTORE TO THE FIRST DATA LINE BEFORE INVOKING.
10810 LET A=0
10815 READ C
10820 IF C<0 THEN RETURN
10825 READ G
10830 READ B
10835 LET I=0
10840 IF I>=B THEN GOTO 10860
10845 READ V
10850 LET O(A+I)=V
10855 LET I=I+1
10856 GOTO 10840
10860 GOSUB 10300
10865 LET A=A+B
10870 GOTO 10815
12000 REM === DISPATCH LOOP ===============================================
12010 REM EXPECTS M, L, P, R PRE-SET BY CALLER.  RUNS UNTIL HALT (OP=0).
12020 IF E<>0 THEN RETURN
12030 IF P>=L THEN RETURN
12040 O=O(M+P)
12050 P=P+1
12060 IF O=0 THEN RETURN
12061 IF O>13 THEN E=1
12062 IF E<>0 THEN RETURN
12070 IF O>7 THEN GOTO 12080
12075 ON O GOSUB 13100,13200,13300,13400,13500,13600,13700
12076 GOTO 12020
12080 ON O-7 GOSUB 13800,13900,14000,14100,14200,14300
12210 GOTO 12020
13100 REM OP 1 PUSH_SELF
13110 V=R
13120 GOSUB 9900
13130 RETURN
13200 REM OP 2 PUSH_LIT (NOT USED BY D1)
13210 P=P+1
13220 E=1
13230 RETURN
13300 REM OP 3 PUSH_TEMP <N>: PUSH STACK[ARG_BASE + N] -----------------
13305 REM ARG_BASE = (CURRENT FRAME'S SAVED CLEANUP_TARGET) + 1; THE
13306 REM CALLER'S RECEIVER SAT AT CLEANUP_TARGET, ARGS START RIGHT AFTER.
13310 A=O(M+P)
13315 P=P+1
13320 IF F<=0 THEN E=21
13322 IF E<>0 THEN RETURN
13325 V=Y(F-1)
13330 V=S(V+1+A)
13335 GOSUB 9900
13340 RETURN
13400 REM OP 4 STORE_TEMP (NOT USED BY D1)
13410 P=P+1
13420 E=1
13430 RETURN
13500 REM OP 5 PUSH_FIELD <N>: PUSH SELF.FIELD(N) ----------------------
13510 A=O(M+P)
13515 P=P+1
13520 V=R
13525 GOSUB 9400
13530 V=H(T+3+A)
13535 GOSUB 9900
13540 RETURN
13600 REM OP 6 STORE_FIELD <N>: SELF.FIELD(N) := POP() ------------------
13610 A=O(M+P)
13615 P=P+1
13620 GOSUB 9960
13625 IF E<>0 THEN RETURN
13630 U=T
13635 V=R
13640 GOSUB 9400
13645 LET H(T+3+A)=U
13650 RETURN
13700 REM OP 7 SEND <SEL> <ARGC> ----------------------------------------
13710 G=O(M+P)
13720 P=P+1
13730 N=O(M+P)
13740 P=P+1
13750 V=S(S-1-N)
13760 GOSUB 9500
13770 C=T
13780 GOSUB 10500
13790 IF Q<0 THEN E=20
13795 IF E<>0 THEN RETURN
13796 GOSUB 14500
13797 RETURN
13800 REM OP 8 RETURN_TOP: POP RESULT, POP FRAME, PUSH RESULT AT BASE ---
13810 REM AT TOP LEVEL (F=0) THIS WOULD UNDERFLOW THE FRAME STACK; INSTEAD
13815 REM JUMP TO END-OF-METHOD SO THE DISPATCH LOOP RETURNS NORMALLY.
13820 IF F<=0 THEN P=L
13822 IF F<=0 THEN RETURN
13825 GOSUB 9960
13827 IF E<>0 THEN RETURN
13830 U=T
13832 F=F-1
13834 P=P(F)
13836 M=M(F)
13838 L=L(F)
13840 R=R(F)
13842 S=Y(F)
13844 V=U
13846 GOSUB 9900
13850 RETURN
13900 REM OP 9 POP
13910 GOSUB 9960
13920 RETURN
14000 REM OP 10 JUMP <OFF>: UNCONDITIONAL JUMP, OFFSET ADDED AFTER -----
14005 REM CONSUMING OPERAND.  OFFSET IS WHATEVER O(M+P) HOLDS; SINCE
14006 REM O() IS A FULL-WIDTH INTEGER ARRAY, BACKWARD JUMPS WORK BY
14007 REM STORING A NEGATIVE OFFSET (NO SIGN-EXTENSION TRICK NEEDED).
14010 V=O(M+P)
14015 P=P+1+V
14020 RETURN
14100 REM OP 11 JUMP_IF_FALSE <OFF>: POP TOP; IF IT IS THE FALSE
14105 REM SINGLETON (HEAP ADDR 8 -> TAGGED REF 16) APPLY THE OFFSET,
14107 REM OTHERWISE FALL THROUGH PAST IT.
14110 V=O(M+P)
14115 P=P+1
14120 GOSUB 9960
14125 IF E<>0 THEN RETURN
14130 IF T=16 THEN P=P+V
14140 RETURN
14200 REM OP 12 PUSH_INT <BYTE> --------------------------------------
14210 V=O(M+P)
14220 P=P+1
14230 GOSUB 9300
14240 V=T
14250 GOSUB 9900
14260 RETURN
14300 REM OP 13 PRIMITIVE <N>
14310 N=O(M+P)
14320 P=P+1
14325 IF N>6 THEN E=22
14326 IF E<>0 THEN RETURN
14330 ON N GOSUB 15100,15200,15300,15400,15500,15600
14395 RETURN
14500 REM --- ACTIVATE METHOD: IN Q=DICT INDEX, N=ARGC, REGS PRE-LOADED -
14510 REM IF METHOD BODY STARTS WITH OPCODE 13 (PRIMITIVE), INVOKE THE
14520 REM PRIMITIVE INLINE WITHOUT PUSHING A FRAME (RECEIVER+ARGS ARE
14525 REM ALREADY ON THE EVAL STACK, AND THE PRIMITIVE POPS THEM AND
14530 REM PUSHES ITS RESULT).  OTHERWISE PUSH A FRAME AND SWITCH P/M/L/R
14535 REM TO THE CALLED METHOD; DISPATCH RESUMES IN THE CALLEE'S BYTECODE.
14540 A=A(Q)
14550 B=B(Q)
14560 D=O(A)
14570 IF D=13 THEN GOTO 14600
14572 IF F>=16 THEN E=4
14574 IF E<>0 THEN RETURN
14576 LET P(F)=P
14577 LET M(F)=M
14578 LET L(F)=L
14579 LET R(F)=R
14580 LET Y(F)=S-1-N
14581 R=S(S-1-N)
14582 F=F+1
14583 P=0
14584 M=A
14585 L=B
14586 RETURN
14600 N=O(A+1)
14605 IF N>6 THEN E=22
14606 IF E<>0 THEN RETURN
14610 ON N GOSUB 15100,15200,15300,15400,15500,15600
14680 RETURN
15100 REM PRIM 1: SMALLINT + ----------------------------------------------
15110 REM EVAL STACK: ... LHS RHS  -- POP TWO, PUSH SUM AS TAGGED INT
15120 GOSUB 9960
15130 IF E<>0 THEN RETURN
15140 V=T
15150 GOSUB 9200
15160 U=T
15170 GOSUB 9960
15180 IF E<>0 THEN RETURN
15190 V=T
15191 GOSUB 9200
15192 V=T+U
15193 GOSUB 9300
15194 V=T
15195 GOSUB 9900
15196 RETURN
15200 REM PRIM 2: SMALLINT - ----------------------------------------------
15210 GOSUB 9960
15220 V=T
15230 GOSUB 9200
15240 U=T
15250 GOSUB 9960
15260 V=T
15270 GOSUB 9200
15280 V=T-U
15290 GOSUB 9300
15295 V=T
15296 GOSUB 9900
15297 RETURN
15300 REM PRIM 3: SMALLINT * ----------------------------------------------
15310 GOSUB 9960
15320 V=T
15330 GOSUB 9200
15340 U=T
15350 GOSUB 9960
15360 V=T
15370 GOSUB 9200
15380 V=T*U
15390 GOSUB 9300
15395 V=T
15396 GOSUB 9900
15397 RETURN
15400 REM PRIM 4: SMALLINT < ----------------------------------------------
15410 GOSUB 9960
15420 V=T
15430 GOSUB 9200
15440 U=T
15450 GOSUB 9960
15460 V=T
15470 GOSUB 9200
15475 IF T<U THEN V=8
15480 IF T>=U THEN V=16
15490 GOSUB 9900
15495 RETURN
15500 REM PRIM 5: PRINT TOP-OF-STACK ----------------------------------
15505 REM HANDLES SMALLINTS AS DECIMAL.  BOOLEANS AND NIL ARE PRINTED
15506 REM AS THEIR CLASS NAMES (TRUE/FALSE/NIL).  ANY OTHER HEAP REF
15507 REM RAISES E=22 (TYPE MISMATCH) - V0 HAS NO PRINTON-DISPATCH YET.
15510 GOSUB 9960
15520 IF E<>0 THEN RETURN
15530 V=T
15535 IF V=0 THEN PRINT "NIL"
15537 IF V=0 THEN GOTO 15590
15540 IF V=8 THEN PRINT "TRUE"
15542 IF V=8 THEN GOTO 15590
15545 IF V=16 THEN PRINT "FALSE"
15547 IF V=16 THEN GOTO 15590
15555 GOSUB 9100
15560 IF T=0 THEN E=22
15562 IF E<>0 THEN RETURN
15570 GOSUB 9200
15580 PRINT T
15590 GOSUB 9900
15594 RETURN
15600 REM PRIM 6: NEW INSTANCE FROM CLASS REF ON STACK --------------------
15610 GOSUB 9960
15620 V=T
15630 GOSUB 9400
15640 D=H(T+3)
15650 C=D
15660 N=H(H(T+3))
15670 N=H(T+3+1)
15680 GOSUB 9700
15690 V=T
15695 GOSUB 9900
15696 RETURN
