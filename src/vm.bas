9000 REM === COR24 SMALLTALK V0 VM CORE =================================
9001 REM HEAP / STACKS / DISPATCH / SEND / PRIMITIVES.
9002 REM ALL HELPERS ARE GOSUB-ONLY -- LINEAR FALL-THROUGH STOPS AT THE
9003 REM DRIVER'S "END" BEFORE LINE 9000.  ARGUMENT PASSING IS BY
9004 REM SHARED VARIABLE; SEE COMMENT AT EACH HELPER FOR INPUT/OUTPUT.
9005 REM
9006 REM ADDRESS LAYOUT WITHIN THE BASIC PEEK/POKE SCRATCH RAM (0..1023):
9007 REM   0..15    NIL/TRUE/FALSE SINGLETONS
9008 REM   16..511  HEAP ARENA (BUMP-ALLOCATED VIA H)
9009 REM   512..639 BYTECODE POOL (1 BYTE PER WORD, 128 BYTES MAX)
9010 REM   640..703 METHOD DICTIONARY (16 ENTRIES * 4 WORDS)
9011 REM   704..735 SYMBOL TABLE (UNUSED IN V0)
9012 REM   736..751 CLASS TABLE (16 SLOTS)
9013 REM   752..767 RESERVED
9014 REM   768..895 EVAL STACK (128 WORDS)
9015 REM   896..991 FRAME STACK (16 FRAMES * 6 WORDS)
9016 REM   992..1023 VM SCRATCH
9017 REM
9018 REM REGISTER USE: P=PC, M=METHOD ADDR, L=METHOD LEN, R=RECEIVER,
9019 REM C=CLASS, S=ESTACK PTR, F=FSTACK PTR, O=OPCODE, G=SELECTOR,
9020 REM N=ARGC, H=HEAP ALLOC, E=ERROR, A/B/D/Q/T/U/V/W=SCRATCH.
9021 REM I/J ARE LOOP-LOCAL IN HELPERS; THE DRIVER USES X/Y/Z.
9022 REM
9100 REM --- ISINT: IN V, OUT T (1 IF SMALLINT, 0 IF POINTER) -------------
9110 T=V-(V/2)*2
9120 RETURN
9200 REM --- TOINT: IN V (TAGGED SMALLINT), OUT T = DECODED INT ------------
9210 T=(V-1)/2
9220 RETURN
9300 REM --- MKINT: IN V (RAW INT), OUT T = TAGGED REF --------------------
9310 T=V*2+1
9320 RETURN
9400 REM --- PADDR: IN V (TAGGED HEAP REF), OUT T = SCRATCH ADDRESS -------
9410 T=V/2
9420 RETURN
9500 REM --- CLASSOF: IN V, OUT T = CLASS ID -----------------------------
9510 GOSUB 9100
9520 IF T=1 THEN T=2
9530 IF T=2 THEN RETURN
9540 GOSUB 9400
9550 T=PEEK(T)
9560 RETURN
9700 REM --- ALLOC: IN C=CLASS, N=SIZE, OUT T = TAGGED REF ---------------
9710 IF H+3+N>512 THEN E=4
9720 IF E<>0 THEN RETURN
9730 POKE H,C
9740 POKE H+1,N
9750 POKE H+2,0
9760 T=H*2
9770 H=H+3+N
9780 RETURN
9900 REM --- EPUSH: IN V, EFFECT: STACK[S++] = V -------------------------
9910 IF S>=128 THEN E=4
9920 IF E<>0 THEN RETURN
9930 POKE 768+S,V
9940 S=S+1
9950 RETURN
9960 REM --- EPOP: OUT T = STACK[--S] ------------------------------------
9970 IF S<=0 THEN E=4
9980 IF E<>0 THEN RETURN
9985 S=S-1
9990 T=PEEK(768+S)
9995 RETURN
10100 REM --- INSTALL_SINGLETONS: REQUIRED ONCE AT BOOT -------------------
10110 REM PLACES NIL (CLASS 5), TRUE (CLASS 3), FALSE (CLASS 4) AT
10120 REM HEAP ADDRESSES 0, 4, 8.  H IS BUMPED PAST THEM TO 16.
10130 POKE 0,5
10140 POKE 1,0
10150 POKE 2,0
10160 POKE 4,3
10170 POKE 5,0
10180 POKE 6,0
10190 POKE 8,4
10200 POKE 9,0
10210 POKE 10,0
10220 POKE 12,6
10230 POKE 13,0
10240 POKE 14,0
10250 H=16
10260 RETURN
10300 REM --- INSTALL_METHOD: IN C=CLASS, G=SEL, A=BCSTART, B=BCLEN -------
10310 REM WALK METHOD DICT (640..703, 16 ENTRIES * 4 WORDS) FOR FIRST
10320 REM EMPTY SLOT (CLASS = -1 OR 0) AND WRITE THE ENTRY.
10330 W=0
10340 IF W>=16 THEN E=4
10350 IF E<>0 THEN RETURN
10360 IF PEEK(640+W*4)<=0 THEN GOTO 10380
10370 W=W+1
10375 GOTO 10340
10380 POKE 640+W*4,C
10390 POKE 640+W*4+1,G
10400 POKE 640+W*4+2,A
10410 POKE 640+W*4+3,B
10420 RETURN
10500 REM --- LOOKUP: IN C=CLASS, G=SEL, OUT Q=ENTRY INDEX OR -1 ----------
10510 W=0
10520 IF W>=16 THEN Q=-1
10530 IF W>=16 THEN RETURN
10540 IF PEEK(640+W*4)<>C THEN GOTO 10570
10550 IF PEEK(640+W*4+1)<>G THEN GOTO 10570
10560 Q=W
10565 RETURN
10570 W=W+1
10580 GOTO 10520
10700 REM --- INIT_METHDICT: MARK ALL ENTRIES EMPTY (CLASS = -1) ---------
10710 W=0
10720 IF W>=16 THEN RETURN
10730 POKE 640+W*4,-1
10740 W=W+1
10750 GOTO 10720
12000 REM === DISPATCH LOOP ===============================================
12010 REM EXPECTS M, L, P, R PRE-SET BY CALLER.  RUNS UNTIL HALT (OP=0).
12020 IF E<>0 THEN RETURN
12030 IF P>=L THEN RETURN
12040 O=PEEK(M+P)
12050 P=P+1
12060 IF O=0 THEN RETURN
12070 IF O=1 THEN GOSUB 13100
12080 IF O=2 THEN GOSUB 13200
12090 IF O=3 THEN GOSUB 13300
12100 IF O=4 THEN GOSUB 13400
12110 IF O=5 THEN GOSUB 13500
12120 IF O=6 THEN GOSUB 13600
12130 IF O=7 THEN GOSUB 13700
12140 IF O=8 THEN GOSUB 13800
12150 IF O=9 THEN GOSUB 13900
12160 IF O=10 THEN GOSUB 14000
12170 IF O=11 THEN GOSUB 14100
12180 IF O=12 THEN GOSUB 14200
12190 IF O=13 THEN GOSUB 14300
12200 IF O>13 THEN E=1
12210 GOTO 12020
13100 REM OP 1 PUSH_SELF
13110 V=R
13120 GOSUB 9900
13130 RETURN
13200 REM OP 2 PUSH_LIT (NOT USED BY D1)
13210 P=P+1
13220 E=1
13230 RETURN
13300 REM OP 3 PUSH_TEMP <N>: PUSH STACK[ARG_BASE + N] -----------------
13305 REM ARG_BASE = (CURRENT FRAME'S SAVED CLEANUP_TARGET) + 1; THE
13306 REM CALLER'S RECEIVER SAT AT CLEANUP_TARGET, ARGS START RIGHT AFTER.
13310 A=PEEK(M+P)
13315 P=P+1
13320 IF F<=0 THEN E=21
13322 IF E<>0 THEN RETURN
13325 V=PEEK(896+(F-1)*5+4)
13330 V=PEEK(768+V+1+A)
13335 GOSUB 9900
13340 RETURN
13400 REM OP 4 STORE_TEMP (NOT USED BY D1)
13410 P=P+1
13420 E=1
13430 RETURN
13500 REM OP 5 PUSH_FIELD <N>: PUSH SELF.FIELD(N) ----------------------
13510 A=PEEK(M+P)
13515 P=P+1
13520 V=R
13525 GOSUB 9400
13530 V=PEEK(T+3+A)
13535 GOSUB 9900
13540 RETURN
13600 REM OP 6 STORE_FIELD <N>: SELF.FIELD(N) := POP() ------------------
13610 A=PEEK(M+P)
13615 P=P+1
13620 GOSUB 9960
13625 IF E<>0 THEN RETURN
13630 U=T
13635 V=R
13640 GOSUB 9400
13645 POKE T+3+A,U
13650 RETURN
13700 REM OP 7 SEND <SEL> <ARGC> ----------------------------------------
13710 G=PEEK(M+P)
13720 P=P+1
13730 N=PEEK(M+P)
13740 P=P+1
13750 V=PEEK(768+S-1-N)
13760 GOSUB 9500
13770 C=T
13780 GOSUB 10500
13790 IF Q<0 THEN E=20
13795 IF E<>0 THEN RETURN
13796 GOSUB 14500
13797 RETURN
13800 REM OP 8 RETURN_TOP: POP RESULT, POP FRAME, PUSH RESULT AT BASE ---
13810 REM AT TOP LEVEL (F=0) THIS WOULD UNDERFLOW THE FRAME STACK; INSTEAD
13815 REM JUMP TO END-OF-METHOD SO THE DISPATCH LOOP RETURNS NORMALLY.
13820 IF F<=0 THEN P=L
13822 IF F<=0 THEN RETURN
13825 GOSUB 9960
13827 IF E<>0 THEN RETURN
13830 U=T
13832 F=F-1
13834 P=PEEK(896+F*5)
13836 M=PEEK(896+F*5+1)
13838 L=PEEK(896+F*5+2)
13840 R=PEEK(896+F*5+3)
13842 S=PEEK(896+F*5+4)
13844 V=U
13846 GOSUB 9900
13850 RETURN
13900 REM OP 9 POP
13910 GOSUB 9960
13920 RETURN
14000 REM OP 10 JUMP <OFF>: UNCONDITIONAL JUMP, OFFSET ADDED AFTER -----
14005 REM CONSUMING OPERAND.  OFFSET IS WHATEVER THE OPERAND BYTE
14006 REM CONTAINS; FOR PEEK BELOW 1024 THIS IS THE FULL SIGNED WORD,
14007 REM SO BACKWARD JUMPS WORK BY POKE-ING A NEGATIVE OFFSET.
14010 V=PEEK(M+P)
14015 P=P+1+V
14020 RETURN
14100 REM OP 11 JUMP_IF_FALSE <OFF>: POP TOP; IF IT IS THE FALSE
14105 REM SINGLETON (HEAP ADDR 8 -> TAGGED REF 16) APPLY THE OFFSET,
14107 REM OTHERWISE FALL THROUGH PAST IT.
14110 V=PEEK(M+P)
14115 P=P+1
14120 GOSUB 9960
14125 IF E<>0 THEN RETURN
14130 IF T=16 THEN P=P+V
14140 RETURN
14200 REM OP 12 PUSH_INT <BYTE> --------------------------------------
14210 V=PEEK(M+P)
14220 P=P+1
14230 GOSUB 9300
14240 V=T
14250 GOSUB 9900
14260 RETURN
14300 REM OP 13 PRIMITIVE <N>
14310 N=PEEK(M+P)
14320 P=P+1
14330 IF N=1 THEN GOSUB 15100
14340 IF N=2 THEN GOSUB 15200
14350 IF N=3 THEN GOSUB 15300
14360 IF N=4 THEN GOSUB 15400
14370 IF N=5 THEN GOSUB 15500
14380 IF N=6 THEN GOSUB 15600
14390 IF N>6 THEN E=22
14395 RETURN
14500 REM --- ACTIVATE METHOD: IN Q=DICT INDEX, N=ARGC, REGS PRE-LOADED -
14510 REM IF METHOD BODY STARTS WITH OPCODE 13 (PRIMITIVE), INVOKE THE
14520 REM PRIMITIVE INLINE WITHOUT PUSHING A FRAME (RECEIVER+ARGS ARE
14525 REM ALREADY ON THE EVAL STACK, AND THE PRIMITIVE POPS THEM AND
14530 REM PUSHES ITS RESULT).  OTHERWISE PUSH A FRAME AND SWITCH P/M/L/R
14535 REM TO THE CALLED METHOD; DISPATCH RESUMES IN THE CALLEE'S BYTECODE.
14540 A=PEEK(640+Q*4+2)
14550 B=PEEK(640+Q*4+3)
14560 D=PEEK(A)
14570 IF D=13 THEN GOTO 14600
14572 IF F>=16 THEN E=4
14574 IF E<>0 THEN RETURN
14576 POKE 896+F*5,P
14577 POKE 896+F*5+1,M
14578 POKE 896+F*5+2,L
14579 POKE 896+F*5+3,R
14580 POKE 896+F*5+4,S-1-N
14581 R=PEEK(768+S-1-N)
14582 F=F+1
14583 P=0
14584 M=A
14585 L=B
14586 RETURN
14600 N=PEEK(A+1)
14610 IF N=1 THEN GOSUB 15100
14620 IF N=2 THEN GOSUB 15200
14630 IF N=3 THEN GOSUB 15300
14640 IF N=4 THEN GOSUB 15400
14650 IF N=5 THEN GOSUB 15500
14660 IF N=6 THEN GOSUB 15600
14670 IF N>6 THEN E=22
14680 RETURN
15100 REM PRIM 1: SMALLINT + ----------------------------------------------
15110 REM EVAL STACK: ... LHS RHS  -- POP TWO, PUSH SUM AS TAGGED INT
15120 GOSUB 9960
15130 IF E<>0 THEN RETURN
15140 V=T
15150 GOSUB 9200
15160 U=T
15170 GOSUB 9960
15180 IF E<>0 THEN RETURN
15190 V=T
15191 GOSUB 9200
15192 V=T+U
15193 GOSUB 9300
15194 V=T
15195 GOSUB 9900
15196 RETURN
15200 REM PRIM 2: SMALLINT - ----------------------------------------------
15210 GOSUB 9960
15220 V=T
15230 GOSUB 9200
15240 U=T
15250 GOSUB 9960
15260 V=T
15270 GOSUB 9200
15280 V=T-U
15290 GOSUB 9300
15295 V=T
15296 GOSUB 9900
15297 RETURN
15300 REM PRIM 3: SMALLINT * ----------------------------------------------
15310 GOSUB 9960
15320 V=T
15330 GOSUB 9200
15340 U=T
15350 GOSUB 9960
15360 V=T
15370 GOSUB 9200
15380 V=T*U
15390 GOSUB 9300
15395 V=T
15396 GOSUB 9900
15397 RETURN
15400 REM PRIM 4: SMALLINT < ----------------------------------------------
15410 GOSUB 9960
15420 V=T
15430 GOSUB 9200
15440 U=T
15450 GOSUB 9960
15460 V=T
15470 GOSUB 9200
15475 IF T<U THEN V=8
15480 IF T>=U THEN V=16
15490 GOSUB 9900
15495 RETURN
15500 REM PRIM 5: PRINT TOP-OF-STACK ----------------------------------
15505 REM HANDLES SMALLINTS AS DECIMAL.  BOOLEANS AND NIL ARE PRINTED
15506 REM AS THEIR CLASS NAMES (TRUE/FALSE/NIL).  ANY OTHER HEAP REF
15507 REM RAISES E=22 (TYPE MISMATCH) - V0 HAS NO PRINTON-DISPATCH YET.
15510 GOSUB 9960
15520 IF E<>0 THEN RETURN
15530 V=T
15535 IF V=0 THEN PRINT "NIL"
15537 IF V=0 THEN GOTO 15590
15540 IF V=8 THEN PRINT "TRUE"
15542 IF V=8 THEN GOTO 15590
15545 IF V=16 THEN PRINT "FALSE"
15547 IF V=16 THEN GOTO 15590
15555 GOSUB 9100
15560 IF T=0 THEN E=22
15562 IF E<>0 THEN RETURN
15570 GOSUB 9200
15580 PRINT T
15590 GOSUB 9900
15594 RETURN
15600 REM PRIM 6: NEW INSTANCE FROM CLASS REF ON STACK --------------------
15610 GOSUB 9960
15620 V=T
15630 GOSUB 9400
15640 D=PEEK(T+3)
15650 C=D
15660 N=PEEK(PEEK(T+3))
15670 N=PEEK(T+3+1)
15680 GOSUB 9700
15690 V=T
15695 GOSUB 9900
15696 RETURN
